rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Wholesale inquiries
    match /inquiries/{inquiryId} {
      allow create: if true; // anyone can submit an inquiry
      allow read, update, delete: if false; // complete protection: no reading or editing allowed
    }
    
    // User profile and settings
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Cart items subcollection
      match /cart/{cartDoc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Orders
    match /orders/{orderId} {
      allow create: if true; // guests or logged-in users can place an order
      allow get: if true; // anyone can track a single order if they have the exact order/tracking ID
      allow list, update, delete: if false; // prevent scanning list of all orders, editing, or deleting
    }
  }
}
